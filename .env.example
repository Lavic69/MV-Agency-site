# =============================================================================
# MV Agency — Variables d'environnement
# =============================================================================
# Copier ce fichier en `.env.local` pour le dev, et renseigner les variables
# côté Vercel (Project Settings → Environment Variables) pour la prod.
#
# Toutes les variables préfixées NEXT_PUBLIC_* sont exposées au navigateur.
# Ne jamais y stocker de secret.
# =============================================================================


# -----------------------------------------------------------------------------
# Vérifications de propriété — Search Engines (gratuits)
# -----------------------------------------------------------------------------
# Google Search Console : https://search.google.com/search-console/welcome
#   1. Ajouter la propriété "https://mvagency.ai"
#   2. Choisir la méthode "Balise HTML" → copier la valeur du `content="..."`
#   3. Coller la valeur ci-dessous (sans guillemets)
NEXT_PUBLIC_GSC_VERIFICATION=

# Bing Webmaster Tools : https://www.bing.com/webmasters
#   1. Ajouter le site (peut être importé depuis GSC en 1 clic)
#   2. Méthode "Meta tag" → copier le contenu (la chaîne après `content="`)
NEXT_PUBLIC_BING_VERIFICATION=


# -----------------------------------------------------------------------------
# Tracking & analytics — Optionnel
# -----------------------------------------------------------------------------
# Vercel Analytics & Speed Insights sont activés AUTOMATIQUEMENT côté Vercel
# dès que les packages sont installés (déjà fait). Aucune variable nécessaire.
# Activation : Vercel Dashboard → Project → Analytics → Enable.

# Microsoft Clarity (heatmap + session recording, gratuit, illimité)
#   ⚠️ Dépose des cookies → nécessite un bandeau de consentement RGPD.
#   Tant que cette variable est vide, le snippet n'est PAS injecté.
#   Création projet : https://clarity.microsoft.com/
NEXT_PUBLIC_CLARITY_ID=

# Google Analytics 4 — non câblé pour l'instant. Le câblage se fera quand
# le ConsentBanner RGPD sera en place. Variable réservée :
# NEXT_PUBLIC_GA_ID=
